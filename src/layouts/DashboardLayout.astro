---
import '../styles/global.css';
import Icon from '../components/ui/Icon.astro';

const { title } = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;

const navItems = [
  { href: `${base}/dashboard`, label: 'الرئيسية', icon: 'grid' },
  { href: `${base}/dashboard/warehouses`, label: 'إدارة المستودعات', icon: 'warehouse' },
  { href: `${base}/dashboard/products`, label: 'إدارة الأصناف', icon: 'package' },
  { href: `${base}/dashboard/grn`, label: 'المشتريات والاستلام', icon: 'fileUp' },
];
---

<html lang="ar" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} - Brandzo ERP 2026` : 'Brandzo ERP 2026'}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: 'Cairo', sans-serif;
        background-color: #f3f4f6;
      }
    </style>
  </head>
  <body class="flex min-h-screen">
    <!-- Sidebar -->
    <aside
      class="fixed inset-y-0 right-0 w-64 bg-brand-navy text-white shadow-xl z-20 flex flex-col"
    >
      <div class="p-6 border-b border-gray-700 flex items-center gap-3">
        <div
          class="w-10 h-10 bg-brand-red rounded-lg flex items-center justify-center font-bold text-xl shadow-lg"
        >
          B
        </div>
        <h1 class="text-xl font-bold tracking-tight">Brandzo ERP</h1>
      </div>

      <nav class="mt-8 px-4">
        <ul class="space-y-2">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-gray-800 transition-colors group"
                >
                  <Icon name={item.icon} class="text-brand-red" />
                  <span class="font-medium">{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="mt-auto border-t border-gray-700">
        <p class="text-xs text-gray-500 text-center font-bold py-4">Brandzo ERP 2026 &copy;</p>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 mr-64 p-8">
      <div class="max-w-7xl mx-auto">
        <slot />
      </div>
    </main>
  </body>
</html>
